# ============================================================
# OpenClaw Agent Configuration
# ============================================================

# LLM Configuration
# ---------------------------------------------------------
# Model name (use litellm/ prefix for third-party models)
# Examples:
#   litellm/deepseek/deepseek-chat    (DeepSeek)
#   litellm/openai/glm-4              (GLM via OpenAI-compatible API)
#   gemini-2.5-flash                   (Google Gemini, native support)
LLM_MODEL=litellm/deepseek/deepseek-chat

# API Key for the LLM provider
LLM_API_KEY=your-api-key-here

# Base URL for the LLM API (required for third-party models)
# DeepSeek: https://api.deepseek.com/v1
# GLM:      https://open.bigmodel.cn/api/paas/v4
LLM_BASE_URL=https://api.deepseek.com/v1

# Feishu Bot Configuration
# ---------------------------------------------------------
# Webhook URL from Feishu group bot settings
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/your-webhook-id

# Optional: Feishu webhook signing secret (for security)
FEISHU_WEBHOOK_SECRET=

# Credentials for Feishu Event Subscription (Bidirectional WS mode)
FEISHU_APP_ID=
FEISHU_APP_SECRET=

# Server Configuration
# ---------------------------------------------------------
PORT=3000

# Cron Notification
# ---------------------------------------------------------
# Feishu chat_id to send cron job results to (optional, auto-captured from first message if empty)
FEISHU_CRON_CHAT_ID=
